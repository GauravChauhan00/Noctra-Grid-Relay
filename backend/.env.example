# Backend runtime
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./noctragrid.db
FRONTEND_URL=http://localhost:5173
APP_BRAND_NAME=NoctraGrid Relay

# Single owner/admin login
# Default local admin login: admin@noctragriddemo.com / NoctraGridAdmin@123
# Change these before production deployment.
ADMIN_NAME=NoctraGrid Owner
ADMIN_EMAIL=admin@noctragriddemo.com
ADMIN_PASSWORD=NoctraGridAdmin@123
ADMIN_SYNC_PASSWORD=true
ALLOW_MULTIPLE_ADMINS=false

# Google App Password / SMTP email service
# For Gmail: enable 2-Step Verification, create an App Password, then paste it here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=gaurav949855@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=NoctraGrid Relay
SMTP_FROM_EMAIL=gaurav949855@gmail.com
SMTP_REPLY_TO_EMAIL=gaurav949855@gmail.com
OWNER_ALERT_EMAIL=gaurav949855@gmail.com
SMTP_STRIP_PASSWORD_SPACES=true
